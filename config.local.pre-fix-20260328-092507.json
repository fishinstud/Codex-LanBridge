{
  "bridge": {
    "agent_id": "ubuntu-ui",
    "mcp_server_name": "lanBridge",
    "state_file": "state/ubuntu-bridge-state.json"
  },
  "broker": {
    "db": "broker.sqlite3",
    "enabled": true,
    "host": "0.0.0.0",
