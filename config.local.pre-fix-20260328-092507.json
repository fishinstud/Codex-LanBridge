    "default_cwd": "/root",
    "default_sandbox": "workspace-write",
    "role_instructions_file": "examples/ubuntu-endpoint-instructions.txt",
    "state_file": "state/ubuntu-endpoint-state.json"
  },
  "machine_role": "ubuntu"
}
