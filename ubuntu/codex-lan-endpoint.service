[Unit]
Description=Codex LAN Endpoint
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/ABS/PATH/TO/codex_lan_bridge
Environment=CODEX_LAN_TOKEN=REPLACE_ME
ExecStart=/usr/bin/python3 /ABS/PATH/TO/codex_lan_bridge/agent_endpoint.py --broker-url http://BROKER_IP:8765 --token REPLACE_ME --agent-id ubuntu-codex --default-cwd /home/YOUR_USER --role-instructions-file /ABS/PATH/TO/codex_lan_bridge/examples/ubuntu-endpoint-instructions.txt
Restart=no

[Install]
WantedBy=multi-user.target
